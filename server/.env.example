# ── AuraFlow server environment ──────────────────────────────────────────────
# Copy this file to server/.env and fill in the values.
#   cp server/.env.example server/.env
# The real server/.env is gitignored and must NEVER be committed.

# Port the Bun server listens on. Default 3001. Bind to 127.0.0.1 only if you
# plan to reach the app via an SSH tunnel or an Nginx reverse proxy.
PORT=3001

# MongoDB connection string. For a 1 GB VPS, prefer MongoDB Atlas (free 512MB
# tier) so the database isn't competing with the app for RAM. Get a string like:
#   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.mongodb.net/auraflow?retryWrites=true&w=majority

# The PIN users type to unlock the app. SHA-256'd server-side into the bearer
# token. Pick something non-trivial.
PIN=change-me-to-a-long-random-secret

# Origin the browser loads the app from. Used for CORS allow-listing and the
# Google OAuth redirect. In production with same-origin static serving this is
# the public URL of your server (or the proxied URL behind Nginx).
CLIENT_URL=http://localhost:5173

# Public base URL the server is reachable at. Required if you use Google
# Calendar integration (it builds the OAuth callback URL from this).
# Example: https://aura.example.com
SERVER_PUBLIC_URL=

# ── Optional: Google Calendar integration (Clock todo sync) ──────────────────
# Leave blank to disable. Get these from Google Cloud Console > Credentials >
# OAuth 2.0 Client ID. Authorized redirect URI must be:
#   ${SERVER_PUBLIC_URL}/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Optional: OpenRouter writing assistant ───────────────────────────────────
# Leave blank to disable. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
