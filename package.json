{
  "name": "auraflow-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["client", "server", "shared"],
  "scripts": {
    "dev": "bun run dev.ts",
    "build": "bun run build:web && bun run build:server",
    "build:web": "bun run --filter client build",
    "build:server": "bun build server/index.ts --outdir server/dist --target bun --minify",
    "start": "bun --smol run server/index.ts",
    "start:bundle": "bun --smol run server/dist/index.js",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check-types": "tsc --noEmit -p server/tsconfig.json && tsc -b client/tsconfig.json",
    "server": "bun --cwd server run --hot index.ts",
    "client": "bun --cwd client run dev",
    "desktop:verify": "node desktop/scripts/verify.mjs",
    "desktop:dev": "bun --cwd desktop run dev",
    "desktop:build": "bun --cwd desktop run package",
    "desktop:build:dir": "bun --cwd desktop run package:dir",
    "fallow": "fallow dead-code --fail-on-issues",
    "fallow:full": "fallow",
    "fallow:fix": "fallow fix --yes",
    "fallow:health": "fallow health"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "fallow": "^2.96.0"
  }
}
