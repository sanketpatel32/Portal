# Production build env. Intentionally empty so the bundle falls back to
# window.location.origin at runtime (see client/src/env.ts). This lets one
# deployment be served from any host/port without rebuilding.
#
# Override here only if the API lives on a different origin than the frontend,
# e.g. VITE_API_URL=https://api.example.com
VITE_API_URL=
VITE_WS_URL=
